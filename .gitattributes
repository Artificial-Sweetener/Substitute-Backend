# Default to normalized text handling for the repository.
* text=auto

# Keep source, config, and docs on LF across platforms.
.gitattributes text eol=lf
.gitignore text eol=lf
*.py text eol=lf
*.pyi text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows-native scripts should keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
